# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,draftly.software,.up.railway.app

# Database — choose one of the two options below:

# Option A: Supabase managed Postgres (production)
# Get this from: Supabase Dashboard → Project → Settings → Database → Connection string → URI
# Use the "Transaction" pooler URL (port 6543) for Django/gunicorn (PgBouncer-compatible)
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Option B: local Postgres via docker compose --profile localdb (development)
DB_NAME=rfp_db
DB_USER=rfp_user
DB_PASSWORD=rfp_pass
DB_HOST=localhost
DB_PORT=5432

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Frontend / API URLs
VITE_API_URL=https://draftly-production-56bf.up.railway.app

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=https://draftly.software,https://www.draftly.software,http://localhost:5173,http://127.0.0.1:5173

# AI Keys — required
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# File storage
# Set True in production to use Supabase Storage; False uses local /media/ directory
USE_SUPABASE_STORAGE=False

# Supabase Storage (S3-compatible) — required when USE_SUPABASE_STORAGE=True
# Get keys from: Supabase Dashboard → Project → Settings → Storage → S3 Access Keys
# SUPABASE_STORAGE_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3
# SUPABASE_STORAGE_BUCKET=documents
# SUPABASE_STORAGE_ACCESS_KEY=<s3-access-key>
# SUPABASE_STORAGE_SECRET_KEY=<s3-secret-key>
# SUPABASE_STORAGE_REGION=us-east-1
